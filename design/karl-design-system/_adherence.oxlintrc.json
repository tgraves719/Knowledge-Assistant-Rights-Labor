{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/chat/**",
              "components/core/**",
              "components/forms/**",
              "components/navigation/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|Playfair Display|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, Playfair Display, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|citation|success|warning|danger|info)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'citation' | 'success' | 'warning' | 'danger' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|disabled|children|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, disabled, children, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|gold|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'gold' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:padded|children|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: padded, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:role|children|key|ref|className|style|children)$/]",
        "message": "<ChatBubble> doesn't accept that prop. Declared props: role, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:assistant|user)$/]",
        "message": "<ChatBubble> role must be one of 'assistant' | 'user'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CitationLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|onClick|key|ref|className|style|children)$/]",
        "message": "<CitationLink> doesn't accept that prop. Declared props: label, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmploymentOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|selected|onClick|key|ref|className|style|children)$/]",
        "message": "<EmploymentOption> doesn't accept that prop. Declared props: title, subtitle, selected, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: style."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuickActionCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|children|onClick|key|ref|className|style|children)$/]",
        "message": "<QuickActionCard> doesn't accept that prop. Declared props: icon, children, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='ShieldMark'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|state|leftColor|rightColor|key|ref|className|style|children)$/]",
        "message": "<ShieldMark> doesn't accept that prop. Declared props: size, state, leftColor, rightColor."
      },
      {
        "selector": "JSXOpeningElement[name.name='ShieldMark'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:idle|thinking)$/]",
        "message": "<ShieldMark> state must be one of 'idle' | 'thinking'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabBarTab'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|key|ref|className|style|children)$/]",
        "message": "<TabBarTab> doesn't accept that prop. Declared props: id, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|key|ref|className|style|children)$/]",
        "message": "<Toggle> doesn't accept that prop. Declared props: checked, onChange, label."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
