# KARL production environment — copy to .env and fill in.
#
#   cp .env.example .env
#
# .env is gitignored. Never commit real values. On a managed host, prefer the
# host secret store and let it inject these as environment variables.
#
# Everything under "Required" is enforced by docker-compose.prod.yml: compose
# refuses to start if any is unset, rather than falling back to an insecure
# default. Optional values below show the code default and only need setting
# when you want to override it.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Managed Postgres 16 with the pgvector extension available (D2). Include
# sslmode=require — managed providers expect TLS and many reject plaintext.
# Note the `+psycopg` driver suffix; a bare postgresql:// URL selects psycopg2,
# which is not installed.
#   postgresql+psycopg://USER:PASSWORD@HOST:5432/karl?sslmode=require
# Confirm `CREATE EXTENSION vector;` is permitted on the instance before
# provisioning for real — not every managed tier allows it.
KARL_POSTGRES_URL=

# Public origin(s) of the deployed site, comma-separated, scheme included.
# Must be the real HTTPS origin in production — the session cookie is marked
# `secure`, so the join flow will not work over plain HTTP.
#   e.g. https://karlstewardship.com
KARL_ALLOWED_ORIGINS=

# Passphrase seeding encryption of tenant secrets at rest, and the HMAC key
# behind anonymized telemetry identifiers.
#
# This is a SEED, not a raw Fernet key: settings.py derives the Fernet key by
# UTF-8 encoding this value, right-padding with "0" to 32 bytes, truncating to
# 32, then base64-encoding. Two consequences:
#   - Only the FIRST 32 BYTES matter. A longer secret is silently truncated.
#   - There is no KDF or stretching, so entropy comes entirely from what you
#     put here. A short or guessable phrase yields a weak key.
# Use exactly 32 characters of high-entropy random text:
#   python -c "import secrets; print(secrets.token_urlsafe(32)[:32])"
#
# Rotating this invalidates stored tenant secrets and breaks continuity of
# anonymized telemetry keys. Back it up with the database.
KARL_SECRET_ENCRYPTION_KEY=

# Database connection budget PER PROCESS (pool_size + max_overflow). Defaults
# to 5 + 5 = 10, sized for a managed plan with a 22-connection cap while
# leaving room for migrations and an admin session. If you ever raise uvicorn's
# worker count, divide these accordingly — the budget multiplies per worker.
#KARL_DB_POOL_SIZE=5
#KARL_DB_MAX_OVERFLOW=5

# Answer generation (Google Gemini). Without it the app boots but cannot answer.
# Set spend caps + alerts on this key before the pilot goes live.
GEMINI_API_KEY=

# Embeddings. The code default backend is "deterministic" — a test stub that
# silently destroys retrieval quality — so production pins "google" and needs a
# real key here. It may be the same key as GEMINI_API_KEY.
KARL_GOOGLE_EMBEDDING_API_KEY=

# ---------------------------------------------------------------------------
# Optional — shown with code defaults
# ---------------------------------------------------------------------------

# Port binding for the api container. Default keeps uvicorn on loopback so the
# public face is the TLS reverse proxy. Set 0.0.0.0 only if the proxy runs on
# a different host.
#KARL_BIND_ADDRESS=127.0.0.1

#KARL_EMBEDDING_BACKEND=google
#KARL_GOOGLE_EMBEDDING_MODEL=text-embedding-004

# Comma-separated emails promoted to super-admin on boot. Used once when
# seeding the production instance; leave unset afterwards.
#KARL_BOOTSTRAP_SUPER_ADMIN_EMAILS=

# Only for the optional bundled-Postgres override (docker-compose.bundled-db.yml,
# local prod-shape testing — never production). If you use it, also point
# KARL_POSTGRES_URL above at postgres:5432 with this same password.
#POSTGRES_DB=karl
#POSTGRES_USER=karl
#POSTGRES_PASSWORD=

# Per-tenant daily quotas. Defaults are sized for pilot scale (~dozens of
# members); revisit alongside the Gemini spend cap.
#KARL_DEFAULT_REQUESTS_PER_DAY=500
#KARL_DEFAULT_TOKENS_PER_DAY=250000
#KARL_DEFAULT_COST_USD_PER_DAY=25

# Rate limits.
#KARL_REQUEST_RATE_LIMIT_PER_MINUTE=60
#KARL_LOGIN_RATE_LIMIT_PER_MINUTE=10

# Session idle timeouts, in seconds. Member sessions are long-lived by design:
# a member who scanned a QR code in the break room should not be signed out
# between shifts.
#KARL_MEMBER_SESSION_IDLE_SECONDS=604800
#KARL_UNION_ADMIN_SESSION_IDLE_SECONDS=259200
#KARL_SUPER_ADMIN_SESSION_IDLE_SECONDS=3600
