{
  "name": "KARL Dev",
  "dockerComposeFile": [
    "../docker-compose.dev.yml"
  ],
  "service": "api",
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",
  "overrideCommand": false,
  "postCreateCommand": "python scripts/dev_preflight.py --profile backend || true",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
